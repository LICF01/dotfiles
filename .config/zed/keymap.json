// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace || Empty",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "ctrl-\\": "workspace::ActivatePreviousPane",
      "space p r": "projects::OpenRecent"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-J": "editor::DuplicateLineDown",
      "ctrl-[": "editor::Fold",
      "ctrl-]": "editor::UnfoldLines",
      "ctrl-{": "editor::FoldAll",
      "ctrl-}": "editor::UnfoldAll"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "U": "editor::Redo",
      "g n": "editor::SelectAllMatches",
      "space a t": "agent::Toggle",
      "space c a": "editor::ToggleCodeActions",
      "space c f": "editor::Format",
      "space c O": "editor::OrganizeImports",
      "space x n": "editor::GoToDiagnostic",
      "space x p": "editor::GoToPreviousDiagnostic",
      "space u c": "workspace::ToggleCenteredLayout",
      "space f e": "project_panel::ToggleFocus",
      "space \\": "project_panel::CollapseAllEntries",
      "space c o": "outline::Toggle",
      "space f f": "file_finder::Toggle",
      "space q a": "pane::CloseAllItems",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "space g d": "editor::ToggleSelectedDiffHunks",
      "space g h r": "git::Restore",
      "space space": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "space c f": "editor::Format"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space f e": "project_panel::Toggle"
    }
  },
  {
    "context": "(ProjectPanel && not_editing) || (Editor && vim_mode == normal)",
    "bindings": {
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "AgentPanel && not_editing",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "S": "vim::PushSneakBackward"
    }
  },
  {
    "context": "VimControl && !menu && vim_mode != operator",
    "bindings": {
      "w": "vim::NextSubwordStart",
      "b": "vim::PreviousSubwordStart",
      "e": "vim::NextSubwordEnd",
      "g e": "vim::PreviousSubwordEnd"
    }
  }
]
